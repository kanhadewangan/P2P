{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "env": {
    "MONGO_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret"
  },
  "buildCommand": "npm install",
  "installCommand": "npm install"
}
